#!/usr/bin/env bash
set -euo pipefail

template="${XDG_CONFIG_HOME:-$HOME/.config}/paseo/paseo.json"
target="$PWD/paseo.json"

if [[ ! -f "$template" ]]; then
  echo "paseo-init: template not found at $template" >&2
  echo "            make sure your home-manager profile is active." >&2
  exit 1
fi

if [[ -e "$target" && ! -L "$target" ]]; then
  echo "paseo-init: $target already exists as a real file; leaving it untouched." >&2
  echo "            (a project paseo.json with worktree/scripts config is usually meant to be committed)" >&2
  exit 0
fi

ln -sfn "$template" "$target"
echo "paseo-init: linked $target -> $template"
echo "           (ignored by git via core.excludesFile; edit the template to change all projects)"
